# Production environment variables (example)
# IMPORTANT:
# - Set secrets (passwords) in your CI/hosting platform; do NOT commit real secrets.
# - Vite inlines VITE_* values at build time. Ensure these are set for the environment where you run `npm run build`.

# Camera / device base URL (example)
VITE_CAMERA_URL=https://camera.example.com
VITE_AUTH_PATH=/cgi-bin/magicBox.cgi?action=getLanguageCaps
VITE_AUTH_METHOD=GET

# RTSP credentials / templates (replace placeholders)
VITE_RTSP_HOST=your.rtsp.host
VITE_RTSP_PORT=554
VITE_RTSP_USERNAME=rtsp_user
VITE_RTSP_PASSWORD=replace_with_secret
VITE_RTSP_LIVE_URL_TEMPLATE=rtsp://{usernameEncoded}:{passwordEncoded}@{host}:{port}/cam/realmonitor?channel={channel}&subtype={subtype}

# HLS / go2rtc gateway
# Recommended: use an origin-relative path when you reverse-proxy go2rtc behind the same domain
# Example (reverse-proxy config forwards /go2rtc -> go2rtc service):

VITE_HLS_GATEWAY_URL=/go2rtc

# Alternatively, if go2rtc is on a separate host, set a full URL (ensure CORS/HTTPS configured):
# VITE_HLS_GATEWAY_URL=https://go2rtc.example.com

VITE_GO2RTC_STREAM_REGISTER_PATH=/go2rtc/api/streams
VITE_GO2RTC_LIVE_PLAYER_TEMPLATE=/go2rtc/stream.html?src={streamEncoded}&mode=mse,hls,webrtc
VITE_GO2RTC_PLAYBACK_PLAYER_TEMPLATE=/go2rtc/stream.html?src={streamEncoded}&mode=mse
VITE_HLS_LIVE_TEMPLATE=/go2rtc/api/stream.m3u8?src={streamEncoded}
VITE_HLS_PLAYBACK_TEMPLATE=/go2rtc/api/stream.m3u8?src={streamEncoded}

VITE_RTSP_PLAYBACK_PATHS=/cam/playback,/cam/realmonitor
VITE_MEDIA_FILEFIND_CLEANUP=false
VITE_MEDIA_FILEFIND_INCLUDE_VIDEO_STREAM=false
VITE_DIGEST_PATH_PREFIXES=/cgi-bin/
